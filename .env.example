# .env - https://github.com/byCrookie/discord-music
# Defaults are commented out. Uncomment to use.
# Values can also be provided without the DISCORD_MUSIC_ prefix, but prefixed
# values have higher priority when both are set.

# Required token from discord application at https://discord.com/developers/applications.
DISCORD_MUSIC_DISCORD__TOKEN=your_discord_bot_token

# clientId and clientSecret from Spotify at https://developer.spotify.com/dashboard/applications.
# DISCORD_MUSIC_SPOTIFY__CLIENT_ID=your_spotify_client_id
# DISCORD_MUSIC_SPOTIFY__CLIENT_SECRET=your_spotify_client_secret

# Path to ffmpeg, yt-dlp, and deno binaries.
# Can be a file or directory path. If a directory path is used, the binary name is appended to the path.
# If empty the binaries are discovered using os specific ways of finding binaries (e.g. PATH environment variable).
# Current directory can be explicitly defined with "."
# DISCORD_MUSIC_YOUTUBE__FFMPEG=ffmpeg
# DISCORD_MUSIC_YOUTUBE__YTDLP=yt-dlp
# DISCORD_MUSIC_YOUTUBE__DENO=deno
# Additional runtimes and remote components for yt-dlp (defaults: deno runtime, ejs:github remote components).
# DISCORD_MUSIC_YOUTUBE__JSRUNTIMES__0=deno
# DISCORD_MUSIC_YOUTUBE__REMOTE_COMPONENTS__0=ejs:github
# DISCORD_MUSIC_YOUTUBE__NO_JS_RUNTIMES=false
# DISCORD_MUSIC_YOUTUBE__NO_REMOTE_COMPONENTS=false

# Container-only: update yt-dlp in the running container every 24 hours.
# Enabled by default; set to false to keep the bundled build-time version.
# DISCORD_MUSIC_YTDLP_AUTO_UPDATE=true

# Max size of the storage directory. If the storage directory exceeds this size, the oldest files are deleted if enough
# space can be freed.
# DISCORD_MUSIC_STORAGE__MAX_SIZE=5GB

# Path to the storage directory. Leave empty to use the OS default location.
# DISCORD_MUSIC_STORAGE__PATH=/app/storage

# Logging follows .NET logging configuration. Values can be Trace, Debug, Information,
# Warning, Error, Critical, or None.
# DISCORD_MUSIC_LOGGING__LOGLEVEL__DEFAULT=Information
# DISCORD_MUSIC_LOGGING__LOGLEVEL__DISCORDMUSIC=Debug
# DISCORD_MUSIC_LOGGING__LOGLEVEL__MICROSOFT=Warning
