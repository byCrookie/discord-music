{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:recommended", ":configMigration", "helpers:pinGitHubActionDigests"],
    "vulnerabilityAlerts": {
        "labels": ["security"],
        "enabled": true
    },
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update ARG versions in Containerfiles via inline comments",
            "managerFilePatterns": ["/(^|/)Containerfile$/"],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>[^\\s]+)(?: versioning=(?<versioning>[^\\s]+))?\\s+ARG \\w+=(?<currentValue>[^\\s]+)"
            ],
            "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}loose{{/if}}"
        },
        {
            "customType": "regex",
            "description": "Update .NET SDK versions in global.json, GitHub Actions, and helper scripts",
            "managerFilePatterns": [
                "/(^|/)global\\.json$/",
                "/(^|/)\\.github/workflows/[^/]+\\.ya?ml$/",
                "/(^|/)justfile$/"
            ],
            "matchStrings": [
                "\"version\"\\s*:\\s*\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\"",
                "dotnet-version:\\s*['\"]?(?<currentValue>\\d+\\.\\d+\\.\\d+)['\"]?",
                "manifest image=\"mcr\\.microsoft\\.com/dotnet/sdk\" tag=\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\""
            ],
            "depNameTemplate": "dotnet-sdk",
            "datasourceTemplate": "dotnet-version",
            "versioningTemplate": "semver"
        }
    ],
    "packageRules": [
        {
            "description": "Group .NET SDK updates across global.json, GitHub Actions, helpers, and container images",
            "matchDatasources": ["dotnet-version", "docker"],
            "matchPackageNames": ["dotnet-sdk", "mcr.microsoft.com/dotnet/sdk"],
            "groupName": ".NET SDK",
            "versioning": "semver"
        },
        {
            "description": "Pin container image digests",
            "matchDatasources": ["docker"],
            "pinDigests": true
        },
        {
            "description": "Group all minor/patch updates for auto-merge",
            "matchUpdateTypes": ["minor", "patch", "digest"],
            "automerge": true
        },
        {
            "description": "Require manual approval for major version bumps",
            "matchUpdateTypes": ["major"],
            "automerge": false
        }
    ],
    "timezone": "Europe/Zurich",
    "schedule": ["at any time"],
    "dependencyDashboard": true,
    "minimumReleaseAge": "14 days",
    "prCreation": "not-pending",
    "internalChecksFilter": "strict",
    "lockFileMaintenance": {
        "enabled": true,
        "automerge": true,
        "automergeType": "pr",
        "platformAutomerge": true
    },
    "prConcurrentLimit": 0,
    "prHourlyLimit": 0,
    "ignoreTests": false
}
