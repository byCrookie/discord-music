{
    "$schema": "http://json.schemastore.org/launchsettings.json",
    "profiles": {
        "DiscordMusic": {
            "commandName": "Project",
            "commandLineArgs": "--env-file ../../../../.env",
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        "Spotify Search": {
            "commandName": "Project",
            "commandLineArgs": "spotify search --env-file ../../../../.env https://open.spotify.com/playlist/60DEeLRtih1FikS2rb9eVF?si=fe6df37fc83744a6",
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        "YouTube Search": {
            "commandName": "Project",
            "commandLineArgs": "youtube search --env-file ../../../../.env https://music.youtube.com/watch?v=t-hi0yCeOJ0&list=RDAMVMt-hi0yCeOJ0",
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        "YouTube Download": {
            "commandName": "Project",
            "commandLineArgs": "youtube download --env-file ../../../../.env https://music.youtube.com/watch?v=t-hi0yCeOJ0&list=RDAMVMt-hi0yCeOJ0 song",
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        "Lyrics Search": {
            "commandName": "Project",
            "commandLineArgs": "lyrics search --env-file ../../../../.env --title Diamonds --artist Rihanna",
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        "Storage Size": {
            "commandName": "Project",
            "commandLineArgs": "storage size --env-file ../../../../.env",
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        "Storage Clear": {
            "commandName": "Project",
            "commandLineArgs": "storage clear --env-file ../../../../.env",
            "environmentVariables": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "DOTNET_ENVIRONMENT": "Development"
            }
        }
    }
}
