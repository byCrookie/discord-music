services:
    discord-music:
        image: ghcr.io/bycrookie/discord-music:latest
        container_name: dm
        env_file:
            - .env
        volumes:
            - /var/tmp/dm/storage:/app/storage:Z
        # Uncomment when the host architecture differs from the image architecture you want to run.
        # platform: linux/amd64
        # platform: linux/arm64
        restart: unless-stopped
